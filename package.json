{
  "name": "grim-ledger",
  "version": "2.0.0",
  "description": "GrimLedger – Dunkles Idle-RPG",
  "private": true,
  "main": "electron/main.cjs",
  "homepage": "./",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "dist:win": "vite build && electron-builder --win --x64"
  },
  "build": {
    "appId": "com.grimleger.app",
    "productName": "GrimLedger",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "electron/**/*"],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "electron/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "publish": {
      "provider": "github",
      "owner": "P3rc1v4l",
      "repo": "GrimLedger"
    }
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.2",
    "immer": "^10.1.1",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "electron-updater": "^6.3.9",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.10",
    "vite": "^5.4.2"
  }
}
